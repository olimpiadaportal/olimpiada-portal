# OlympIQ — Web App (Student/Parent) environment template.
# Copy this file to `.env.local` and fill with your Supabase DEV/STAGING values.
# Get these from: Supabase Dashboard -> Project Settings -> API.
#
# NEXT_PUBLIC_* values are sent to the browser. ONLY the project URL and the
# anon (public) key are safe to expose there.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# SERVER-ONLY secret (NO NEXT_PUBLIC_ prefix → never sent to the browser).
# Used only by server code (Server Actions / Route Handlers) for privileged
# operations RLS forbids to normal users: child account provisioning, child
# password reset, and login-lockout bookkeeping. It is read exclusively by
# `src/lib/supabase/admin.ts`, which is marked `import "server-only"` so the
# build fails if it is ever pulled into client/browser code. Never log or commit it.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- Notifications (optional; the in-app center works WITHOUT any of these) ----
# Shared secret guarding the delivery processor route (POST /api/notifications/
# process, header `x-processor-key`). Set it + point a scheduler (pg_cron+pg_net
# or an external cron) at the route ONLY when you enable email/push. Server-only.
NOTIFICATIONS_PROCESSOR_KEY=
# Email channel (enable the `notifications_email` flag AND set this to go live):
# an SMTP/provider URL or API key. Empty = email delivery reports not_configured.
NOTIFICATIONS_SMTP_URL=
# Push channel (mobile stage M7; enable `notifications_push` AND set this):
EXPO_ACCESS_TOKEN=
