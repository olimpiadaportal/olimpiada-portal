# Supabase Configuration
# IMPORTANT: Get these from Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=UniPrep Admin

# Optional: IP Whitelist (comma-separated)
# ADMIN_ALLOWED_IPS=192.168.1.1,192.168.1.2

# NOTE: For local development, you can name this file either:
# - .env (works for all environments)
# - .env.local (local development only, not committed to git)

# Brevo SMTP Configuration (for admin panel notification emails)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_login@smtp-brevo.com
SMTP_PASS=your_brevo_smtp_key
SMTP_FROM_EMAIL=your_verified_sender@gmail.com
SMTP_FROM_NAME=Elmly Analytics


CRON_SECRET=your_random_32_char_secret_here

# Notification Processor API Key (used by cron job to trigger notification processing)
NOTIFICATION_PROCESSOR_API_KEY=your_notification_processor_api_key_here

# DeepSeek AI Configuration (for AI prompt testing)
DEEPSEEK_API_KEY=your_deepseek_api_key_here