# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these values from your Supabase project settings (Project Settings > API)

# Your Supabase project URL (example: https://xxxxx.supabase.co)
EXPO_PUBLIC_SUPABASE_URL=your_project_url_here

# Your Supabase anon/public key (starts with eyJ...)
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ============================================
# EAS BUILD CONFIGURATION
# ============================================
# Get these from expo.dev after running 'eas init'

# Your Expo username (from expo.dev account)
EXPO_OWNER=your_expo_username

# EAS Project ID (UUID from expo.dev → Project → Overview)
EAS_PROJECT_ID=your_project_id_here

# ============================================
# STRIPE CONFIGURATION (Phase 8)
# ============================================
# Get these from https://dashboard.stripe.com/apikeys
# Use test keys (pk_test_... / sk_test_...) during development
# Switch to live keys (pk_live_... / sk_live_...) for production

# Publishable key — safe to expose in client apps
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Secret key — ONLY set this in Supabase Edge Function secrets, NEVER here
# Run: supabase secrets set STRIPE_SECRET_KEY=sk_test_...
# STRIPE_SECRET_KEY=sk_test_your_secret_key_here  ← DO NOT COMMIT

# Webhook signing secret — ONLY set this in Supabase Edge Function secrets
# Get from Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
# Run: supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here  ← DO NOT COMMIT

# ============================================
# DEEPSEEK AI CONFIGURATION (Stage 9.5)
# ============================================

# DeepSeek API Key (get from https://platform.deepseek.com)
# IMPORTANT: This should ONLY be used in Supabase Edge Functions (backend)
# NEVER expose this in the React Native app
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek Models Configuration
# deepseek-chat: Fast, general-purpose (insights, analysis)
# deepseek-coder: Optimized for structured output (JSON, code) - 30-40% faster for questions
# deepseek-reasoner: Advanced reasoning (complex explanations, math problems)
DEEPSEEK_MODEL_CHAT=deepseek-chat
DEEPSEEK_MODEL_CODER=deepseek-coder
DEEPSEEK_MODEL_REASONER=deepseek-reasoner

# Model Selection Strategy (which model to use for each feature)
# insights: deepseek-chat (fast analysis)
# explanations: deepseek-reasoner (complex reasoning)
# questions: deepseek-coder (optimized for JSON generation - HARDCODED in Edge Function)
AI_MODEL_INSIGHTS=deepseek-chat
AI_MODEL_EXPLANATIONS=deepseek-reasoner
AI_MODEL_QUESTIONS=deepseek-coder
