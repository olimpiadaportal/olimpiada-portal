# OlympIQ — Admin Panel (Administrator/Content Manager) environment template.
# Copy this file to `.env.local` and fill with your Supabase DEV/STAGING values.
# Get these from: Supabase Dashboard -> Project Settings -> API.
#
# NEXT_PUBLIC_* values are sent to the browser (safe: project URL + anon key only).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# SERVER-ONLY (NOT used yet; added in a later stage for privileged admin operations).
# NEVER prefix with NEXT_PUBLIC and NEVER expose to the browser. Only read in
# server code / route handlers / server actions.
# SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
