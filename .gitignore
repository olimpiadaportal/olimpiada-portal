# ---------------------------------------------------------------------------
# Olimpiada Portal — root .gitignore
# Covers Next.js (web-app, admin-panel), Node, Supabase tooling, OS and editor junk.
# Individual apps may add their own .gitignore later; this is the safe baseline.
# ---------------------------------------------------------------------------

# --- Secrets and environment variables -------------------------------------
# Never commit real secrets. Commit *.example templates instead.
.env
.env.*
*.env
!.env.example
!.env.*.example
.env.local
.env.development.local
.env.test.local
.env.production.local
secrets/
*.pem
*.key
*.p12
*.pfx

# --- Dependencies ----------------------------------------------------------
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnpm-store/

# --- Build / output artifacts ----------------------------------------------
.next/
out/
build/
dist/
.turbo/
.vercel/
*.tsbuildinfo
next-env.d.ts

# --- Testing / coverage ----------------------------------------------------
coverage/
.nyc_output/
playwright-report/
test-results/

# --- Logs ------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Supabase --------------------------------------------------------------
# Ignore local CLI runtime/temp state and generated secrets,
# but keep versioned SQL under supabase/sql/ tracked.
supabase/.branches/
supabase/.temp/
supabase/.env
**/supabase/.env
.supabase/

# --- Caches ----------------------------------------------------------------
.cache/
.eslintcache
.stylelintcache
.parcel-cache/

# --- OS files --------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Editor / IDE junk -----------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project

# --- Local agent / tooling config ------------------------------------------
# Personal, machine-local Claude Code settings (permission allowlists, etc.).
# A shared .claude/settings.json may be committed if the team wants one.
.claude/settings.local.json
