# OlympIQ mobile — public runtime config (EXPO_PUBLIC_* values are embedded in
# the JS bundle; ONLY ever put the anon key here, NEVER a service-role key).
# Copy to .env (git-ignored) for local development; EAS profiles set these per
# environment (development/preview -> dev Supabase, production -> prod).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# The web-app origin hosting the mobile BFF (/api/mobile/v1/*).
#
# SAME NETWORK (phone + PC on one Wi-Fi):
#   Leave this as localhost. src/lib/env.ts auto-rewrites "localhost" to the
#   Expo dev machine's LAN IP so a physical phone can reach the BFF. The web-app
#   dev server must be running (`npm run dev` in web-app/) and the PC's firewall
#   must allow inbound TCP 3000.
#
# REMOTE TESTER / `expo start --tunnel` (phone on another network):
#   localhost does NOT work here — the Expo tunnel forwards only the Metro
#   bundler, never port 3000, so the BFF is unreachable and STUDENT LOGIN plus
#   every write fail (parent login still works: it talks to Supabase directly).
#   The rewrite is skipped for tunnel/remote hosts on purpose; you must point
#   this at a PUBLIC https origin that reaches the BFF, either:
#     - your deployed web-app (e.g. https://<app>.vercel.app) — best; no tunnel
#       to babysit — AS LONG AS that deploy targets the SAME Supabase project
#       this app uses (Bearer tokens are validated there), or
#     - a tunnel to the local dev server, e.g.
#         cloudflared tunnel --url http://localhost:3000   (no account)
#       then set EXPO_PUBLIC_BFF_URL to the printed https URL and restart Expo.
EXPO_PUBLIC_BFF_URL=http://localhost:3000
